##################################################
# 🎵 Music Player Project - .gitignore
# Author: Jamuna Sri
# Purpose: Ignore unnecessary files from Git tracking
##################################################

############################
# 📦 Node Modules
############################
node_modules/

############################
# 📁 TypeScript Output Files
############################
# Ignore compiled JavaScript if you want to track only TS
*.js
*.js.map

############################
# 📄 Logs
############################
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

############################
# ⚙️ Environment Variables
############################
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

############################
# 💻 IDE / Editor Files
############################
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

############################
# 🖥️ OS Generated Files
############################
.DS_Store
Thumbs.db
Desktop.ini

############################
# 🧪 Testing & Coverage
############################
coverage/
*.lcov

############################
# 🗂️ Cache Files
############################
.cache/
.parcel-cache/
dist/
build/

############################
# 🔐 Optional Security Files
############################
*.pem
*.key

############################
# 📌 Temporary Files
############################
*.tmp
*.temp
*.swp

############################
# 🚫 Miscellaneous
############################
npm-packages-offline-cache/
.eslintcache
.stylelintcache
